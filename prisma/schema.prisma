generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String?
  email     String   @unique
  college   String?
  branch    String?
  year      Int?
  cgpa      Float?
  createdAt DateTime @default(now())
}