generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String?
  email     String   @unique
  college   String?
  branch    String?
  year      Int?
  cgpa      Float?
  role      String   @default("student") 
  quizAttempts QuizAttempt[]
  companyInterests CompanyInterest[]
  notifications Notification[]
  createdAt DateTime @default(now())

  solvedProblems UserProblem[]
}

model Problem {
  id          String   @id @default(cuid())
  title       String
  difficulty  String
  tags        String[]
  companies   String[]
  leetcodeUrl String
  createdAt   DateTime @default(now())

  solvedBy UserProblem[]
}

model UserProblem {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  solved    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([userId, problemId])
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String
  ctc         Float
  minCgpa     Float
  date        String
  branches    String[]
  rounds      String[]
  description String?
  website     String?
  location    String?
  employees   String?
  createdAt   DateTime @default(now())

  interests CompanyInterest[]
}

model CompanyInterest {
  id            String   @id @default(cuid())
  userId        String
  companyId     String
  status        String   @default("registered") // registered, round1, round2, selected, rejected
  currentRound  Int      @default(0)
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}


model Quiz {
  id       String     @id @default(cuid())
  title    String
  category String
  duration Int
  createdAt DateTime  @default(now())

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  question      String
  options       String[]
  correctIndex  Int
  explanation   String?
  createdAt     DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  totalQ      Int
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id])
}




model StudyMaterial {
  id        String   @id @default(cuid())
  subject   String   // "OS", "DBMS", "CN"
  topic     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}


model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}